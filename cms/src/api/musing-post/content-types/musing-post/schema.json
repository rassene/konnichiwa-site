{
  "kind": "collectionType",
  "collectionName": "musing_posts",
  "info": {
    "singularName": "musing-post",
    "pluralName": "musing-posts",
    "displayName": "Musing Post",
    "description": "Short-form written content: essays, notes, threads, quotes"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true,
      "maxLength": 200
    },
    "format": {
      "type": "enumeration",
      "enum": ["essay", "note", "thread", "quote"],
      "required": true,
      "default": "note"
    },
    "tier": {
      "type": "enumeration",
      "enum": ["public", "subscriber"],
      "required": true,
      "default": "public"
    },
    "publishedAt": {
      "type": "datetime",
      "required": true
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "clusters": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::interest-cluster.interest-cluster",
      "mappedBy": "musings"
    }
  }
}
