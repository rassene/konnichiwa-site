# cms/.env.example — copy to .env for local development
HOST=0.0.0.0
PORT=1337
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=changeme_salt
ADMIN_JWT_SECRET=changeme_admin_jwt
TRANSFER_TOKEN_SALT=changeme_transfer
JWT_SECRET=changeme_jwt

DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Azure Blob Storage (leave empty to use local file storage in dev)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=media
CDN_BASE_URL=
