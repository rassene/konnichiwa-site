---
// Shell layer — gated reading note teaser (T086).
// Non-gated notes render server-side (zero JS).
// Gated notes hydrate GatedNoteTeaserIsland (client:load) to verify subscriber token.
// JS cost for gated notes: ~3 KB React island — justified by subscriber gate requirement.
import GatedNoteTeaserIsland from './GatedNoteTeaserIsland.tsx';

interface Props {
  note: string;
  isGated: boolean;
  /** Cluster slugs the reading belongs to — determines subscriber access. */
  clusterSlugs?: string[];
}

const { note, isGated, clusterSlugs = [] } = Astro.props;
---

{isGated ? (
  <GatedNoteTeaserIsland
    client:load
    note={note}
    clusterSlugs={clusterSlugs}
  />
) : (
  <p class="reading-note">{note}</p>
)}

<style>
  .reading-note {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    padding: var(--space-md);
    border-left: 3px solid var(--color-accent-soft);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
</style>
