---
/**
 * Shell layer — full-viewport hero block.
 * JS cost: ~14 KB gzipped for WelcomeBack island (FingerprintJS OSS).
 * Justified: powers returning-visitor personalisation and admin presence dashboard.
 */
import WelcomeBack from "./WelcomeBack.tsx";
---

<section class="hero" aria-label="Introduction">
  <div class="hero__inner">
    <WelcomeBack client:load />
    <p class="hero__eyebrow">hey, I'm</p>
    <h1 class="hero__name">
      <!-- Owner: replace with your display name -->
      <span class="hero__name-text">Your Name</span>
      <span class="hero__dot" aria-hidden="true">.</span>
    </h1>
    <p class="hero__tagline">
      Engineer. Reader. Sister. Dreamer.
    </p>
    <a href="#projects" class="hero__scroll-cue" aria-label="Scroll to explore">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="1.5"
          stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl) var(--space-md);
    background-color: var(--color-background);
  }

  .hero__inner {
    max-width: 720px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    text-transform: lowercase;
  }

  .hero__name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 700;
    line-height: 1.05;
    color: var(--color-text);
    margin: 0;
  }

  .hero__dot {
    color: var(--color-accent);
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.5vw, 1.375rem);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .hero__scroll-cue {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    margin-top: var(--space-xl);
    text-decoration: none;
    transition: color var(--motion-base), border-color var(--motion-base),
      transform var(--motion-base);
    animation: hero-bounce 2s ease-in-out infinite;
  }

  .hero__scroll-cue:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(2px);
  }

  @keyframes hero-bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(6px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-cue {
      animation: none;
    }
  }
</style>
