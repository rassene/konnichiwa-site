---
// Shell layer — musing post card, tier-aware.
// Public posts: zero JS. Gated posts: hydrate SubscriberGateIsland (client:load) to
// verify subscriber token and replace lock CTA with post link if access is confirmed.
// JS cost for gated posts: ~3 KB (React island) — justified by T085 subscriber gate requirement.
import type { IMusingPost, IInterestCluster } from '../../content/interfaces/index.js';
import Tag from '../../components/Tag.astro';
import SubscriberGateIsland from './SubscriberGateIsland.tsx';

interface Props {
  post: IMusingPost;
  clusters: IInterestCluster[];
}

const { post, clusters } = Astro.props;

const FORMAT_LABELS: Record<IMusingPost['format'], string> = {
  essay:  'Essay',
  note:   'Note',
  thread: 'Thread',
  quote:  'Quote',
};

const postClusters = clusters.filter((c) => post.clusters.includes(c.slug));
const isGated = post.tier === 'subscriber';

const dateFormatted = new Date(post.publishedAt).toLocaleDateString('en-GB', {
  year: 'numeric', month: 'short', day: 'numeric',
});
---

<article class:list={['musing-card', { 'musing-card--gated': isGated }]}>
  <header class="musing-card__header">
    <div class="musing-card__meta">
      <span class="musing-card__format">{FORMAT_LABELS[post.format]}</span>
      {isGated && <span class="musing-card__lock" aria-label="Subscriber only" title="Subscriber only">🔒</span>}
      <time class="musing-card__date" datetime={post.publishedAt}>{dateFormatted}</time>
    </div>
    <h3 class="musing-card__title">
      {isGated ? post.title : (
        <a href={`/musings/${post.slug}`} class="musing-card__link">{post.title}</a>
      )}
    </h3>
  </header>

  <p class="musing-card__excerpt">
    {isGated ? post.excerpt : post.excerpt}
  </p>

  {!isGated && (
    <a href={`/musings/${post.slug}`} class="musing-card__read-more" aria-label={`Read ${post.title}`}>
      Read more →
    </a>
  )}

  {isGated && (
    <SubscriberGateIsland
      client:load
      slug={post.slug}
      requiredClusters={post.clusters}
      title={post.title}
    />
  )}

  {postClusters.length > 0 && (
    <footer class="musing-card__footer">
      <ul class="musing-card__clusters" role="list">
        {postClusters.map((c) => (
          <li><Tag color={c.color}>{c.label}</Tag></li>
        ))}
      </ul>
    </footer>
  )}
</article>

<style>
  .musing-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .musing-card--gated {
    opacity: 0.85;
  }

  .musing-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .musing-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .musing-card__format {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .musing-card__lock {
    font-size: 0.875rem;
  }

  .musing-card__date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-left: auto;
  }

  .musing-card__title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .musing-card__link {
    color: inherit;
    text-decoration: none;
  }

  .musing-card__link:hover {
    color: var(--color-accent);
  }

  .musing-card__excerpt {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .musing-card__subscribe--loading {
    opacity: 0.4;
  }

  .musing-card__read-more,
  .musing-card__subscribe {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: auto;
    transition: opacity var(--motion-fast);
  }

  .musing-card__read-more:hover,
  .musing-card__subscribe:hover {
    opacity: 0.75;
  }

  .musing-card__footer {
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-sm);
  }

  .musing-card__clusters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
