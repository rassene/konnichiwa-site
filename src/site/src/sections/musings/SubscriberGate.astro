---
// Shell layer — subscriber gate overlay for T1-gated musing posts.
// Shows excerpt + subscribe CTA for T0 users.
// Phase 4 (T085) upgrades this with React island + token verification.
interface Props {
  excerpt: string;
  title: string;
}

const { excerpt, title } = Astro.props;
---

<div class="subscriber-gate" role="complementary" aria-label="Subscriber-only content">
  <div class="subscriber-gate__excerpt">
    <p>{excerpt}</p>
  </div>
  <div class="subscriber-gate__cta">
    <span class="subscriber-gate__lock" aria-hidden="true">🔒</span>
    <p class="subscriber-gate__message">
      The rest of <em>{title}</em> is for subscribers.
    </p>
    <a href="/#subscribe" class="subscriber-gate__btn">
      Subscribe to read the full post →
    </a>
    <p class="subscriber-gate__note">Already subscribed?
      <a href="/#subscribe" class="subscriber-gate__signin">Use your access token →</a>
    </p>
  </div>
</div>

<style>
  .subscriber-gate {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .subscriber-gate__excerpt {
    padding: var(--space-xl);
    background: linear-gradient(to bottom, var(--color-surface), var(--color-background));
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    position: relative;
  }

  .subscriber-gate__excerpt::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, transparent, var(--color-background));
  }

  .subscriber-gate__excerpt p {
    margin: 0;
  }

  .subscriber-gate__cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-xl);
    background-color: var(--color-accent-soft);
    text-align: center;
  }

  .subscriber-gate__lock {
    font-size: 2rem;
  }

  .subscriber-gate__message {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    margin: 0;
  }

  .subscriber-gate__btn {
    display: inline-block;
    padding: var(--space-sm) var(--space-xl);
    background-color: var(--color-accent);
    color: #fff;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity var(--motion-fast);
  }

  .subscriber-gate__btn:hover {
    opacity: 0.88;
  }

  .subscriber-gate__note {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .subscriber-gate__signin {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }
</style>
