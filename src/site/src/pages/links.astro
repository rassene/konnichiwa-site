};
---

<BaseLayout
  title="Links"
  description="A curated list of places to find me online."
>
  <SectionWrapper id="links">
    <header class="links-page__header">
      <h1 class="links-page__title">Links</h1>
      <p class="links-page__desc">
        Places to find me across the internet.
      </p>
    </header>

    {links.length > 0 ? (
      <ul class="links-list" role="list">
        {links.map(({ label, url, icon }) => {
          const iconPath = icon ? ICON_SVGS[icon] : undefined;
          return (
            <li>
              <a
                href={url}
                class="links-list__item"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${label} (opens in new tab)`}
              >
                {iconPath ? (
                  <svg class="links-list__icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
                    <path d={iconPath} fill="currentColor" />
                  </svg>
                ) : (
                  <span class="links-list__icon links-list__icon--text" aria-hidden="true">→</span>
                )}
                <span class="links-list__label">{label}</span>
                <span class="links-list__url">{url.replace(/^https?:\/\//, '')}</span>
                <svg class="links-list__external" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="links-page__empty">Links coming soon.</p>
    )}
  </SectionWrapper>
</BaseLayout>

<style>
  .links-page__header {
    margin-bottom: var(--space-2xl);
  }

  .links-page__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-md);
    line-height: 1.1;
  }

  .links-page__desc {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .links-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 560px;
  }

  .links-list__item {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color var(--motion-base), box-shadow var(--motion-base),
      transform var(--motion-fast);
  }

  .links-list__item:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transform: translateX(4px);
  }

  .links-list__icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .links-list__icon--text {
    font-family: var(--font-mono);
    font-size: 1rem;
  }

  .links-list__label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .links-list__url {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .links-list__url {
      display: none;
    }

    .links-list__item {
      grid-template-columns: auto 1fr auto;
    }
  }

  .links-list__external {
    flex-shrink: 0;
    color: var(--color-text-muted);
    opacity: 0;
    transition: opacity var(--motion-fast);
  }

  .links-list__item:hover .links-list__external {
    opacity: 1;
  }

  .links-page__empty {
    font-family: var(--font-body);
    color: var(--color-text-muted);
  }
</style>
