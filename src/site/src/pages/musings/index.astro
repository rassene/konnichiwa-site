---
// Musings index page — shell layer, T058.
import BaseLayout from '../../layouts/BaseLayout.astro';
import MusingsLanding from '../../sections/musings/MusingsLanding.astro';
import { content } from '../../content/index.js';

const [musings, clusters] = await Promise.all([
  content.getMusings(),
  content.getClusters(),
]);
---

<BaseLayout
  title="Musings"
  description="Notes, essays, and half-formed ideas. Some public, some for subscribers."
>
  <MusingsLanding musings={musings} clusters={clusters} />
</BaseLayout>
