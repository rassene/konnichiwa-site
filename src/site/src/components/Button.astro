---
// Shell layer — reusable button using design tokens.
interface Props {
  href?: string;             // renders as <a> when provided
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  class?: string;
  'aria-label'?: string;
}

const {
  href,
  type = 'button',
  variant = 'primary',
  size = 'md',
  disabled,
  class: className,
  'aria-label': ariaLabel,
} = Astro.props;
---

{href
  ? (
    <a
      href={href}
      class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
      aria-label={ariaLabel}
    >
      <slot />
    </a>
  )
  : (
    <button
      type={type}
      class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
      disabled={disabled}
      aria-label={ariaLabel}
    >
      <slot />
    </button>
  )
}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-weight: 500;
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background-color var(--motion-fast), color var(--motion-fast), border-color var(--motion-fast);
    white-space: nowrap;
  }

  .btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Sizes */
  .btn--sm { font-size: 0.8125rem; padding: var(--space-xs) var(--space-md);  }
  .btn--md { font-size: 0.9375rem; padding: var(--space-sm) var(--space-lg);  }
  .btn--lg { font-size: 1rem;      padding: var(--space-md) var(--space-xl);  }

  /* Variants */
  .btn--primary {
    background-color: var(--color-accent);
    color: var(--color-surface);
    border-color: var(--color-accent);
  }
  .btn--primary:hover:not(:disabled) {
    background-color: color-mix(in srgb, var(--color-accent) 85%, black);
    border-color: color-mix(in srgb, var(--color-accent) 85%, black);
  }

  .btn--secondary {
    background-color: var(--color-accent-soft);
    color: var(--color-accent);
    border-color: var(--color-accent-soft);
  }
  .btn--secondary:hover:not(:disabled) {
    background-color: color-mix(in srgb, var(--color-accent-soft) 80%, var(--color-accent));
  }

  .btn--ghost {
    background-color: transparent;
    color: var(--color-text-muted);
    border-color: var(--color-border);
  }
  .btn--ghost:hover:not(:disabled) {
    background-color: var(--color-accent-soft);
    color: var(--color-accent);
    border-color: var(--color-accent-soft);
  }
</style>
