# src/site/.env.example
# Copy to .env and fill in values for local development.

# Strapi CMS
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your_strapi_api_token_here

# .NET API (public-facing URL — used for fingerprinting + contact form)
PUBLIC_API_URL=http://localhost:5000

# Azure Blob Storage CDN (base URL for media assets)
# Leave empty in local dev — Strapi returns absolute URLs from localhost
PUBLIC_CDN_BASE_URL=
